{
  "name": "memorial-site-server",
  "version": "2.0.0",
  "description": "Memorial site backend (Express + Prisma)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio --port 5557",
    "migrate:from-sqlite": "node scripts/migrate-from-sqlite.js",
    "restore:clans": "node scripts/restore-clans.js",
    "cleanup:photos": "node scripts/cleanup-photos.js --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1055.0",
    "@aws-sdk/lib-storage": "^3.1055.0",
    "@aws-sdk/s3-request-presigner": "^3.1055.0",
    "@prisma/client": "6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "prisma": "6.19.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "file-type": "^22.0.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=22"
  }
}
