    "restore:clans": "node scripts/restore-clans.js"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "prisma": "6.19.3"
  },
  "engines": {
    "node": ">=22"
  }
  
  
}
