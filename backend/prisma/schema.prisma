// ============================================================
//  МЕМОРИАЛЬНЫЙ САЙТ «ПАМЯТЬ» — единая схема (v2)
//  PostgreSQL + Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  ENUMS
// ============================================================







// Типизация 6 дефолтных блоков биографии (п. 1.4)










// ============================================================
//  AUTH / USERS
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  // PBKDF2-SHA512: хранится строкой формата "iterations:saltHex:hashHex"
  passwordHash String
  jwtVersion   Int      @default(0)
  displayName  String?
  role         String @default("USER")
  telegramId   BigInt?  @unique // привязка к боту (объединение bot.db)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Что человек создал/чем владеет
  ownedProfiles          Profile[]         @relation("ProfileOwner")
  guestMemories          GuestMemory[] // если оставил воспоминание авторизованным
  candleLights           CandleLight[]
  accessGrants           ProfileAccess[]
  tgLoginTokens          TgLoginToken[]
  editorOf               ProfileAccess[]   @relation("EditorGrants")
  uploadedMedia          Media[]
  auditLogs              AuditLog[]
  // 👇 НОВОЕ: автор исторических/timeline-событий (аудит)
  createdTimelineEvents  TimelineEvent[]   @relation("TimelineEventAuthor")

  @@index([role])
  passwordResetTokens PasswordResetToken[]
  acceptedTermsAt   DateTime?
  acceptedTermsIp   String?

  // === Disputes / Merge / Legacy Contact (Phase 1) ===
  lastSeenAt           DateTime?
  legacyInactivityDays Int       @default(90)

  disputesCreated      ProfileDispute[]      @relation("DisputeReporter")
  mergeRequestsCreated ProfileMergeRequest[] @relation("MergeRequester")
  legacyContactAsOwner LegacyContact?        @relation("LegacyContactOwner")
  legacyContactAsHeir  LegacyContact[]       @relation("LegacyContactHeir")
  legacyClaims         LegacyClaim[]
}

// ============================================================
//  PROFILE — страница памяти
// ============================================================

model Profile {
  id           String    @id @default(cuid())
  slug         String    @unique // для красивых URL: /p/ivan-petrov
  fullName     String
  birthDate    DateTime?
  deathDate    DateTime?
  birthPlace   String?
  deathPlace   String?
  burialPlace  String?
  burialLat    Float?
  burialLng    Float?
  bio          String?    // короткое intro (hero subtitle)
  coverPhotoId String?   @unique
  coverPhoto   Media?    @relation("ProfileCover", fields: [coverPhotoId], references: [id], onDelete: SetNull)
  gender       String    @default("UNKNOWN")

  // Видимость и защита
  visibility String @default("PUBLIC")
  // Пароль страницы: PBKDF2 в том же формате "iterations:saltHex:hashHex".
  // NULL если visibility != PASSWORD
  accessHash String?

  ownerId String
  owner   User   @relation("ProfileOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  // Привязка к узлу в семейном дереве (1:1, опционально)
  familyNodeId String?     @unique
  familyNode   FamilyNode? @relation(fields: [familyNodeId], references: [id], onDelete: SetNull)

  // Связи
  blocks         ContentBlock[]
  galleryItems   GalleryItem[]
  guestMemories  GuestMemory[]
  candleLights   CandleLight[]
  accessGrants   ProfileAccess[]
  timelineEvents TimelineEvent[] // личные события, не привязанные к FamilyNode
  qrPlaques      QrPlaque[]

  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  deletedAt    DateTime?
  searchVector Unsupported("tsvector")?
  accessCodes  ProfileAccessCode[]

  // === Disputes / Merge (Phase 1) ===
  disputes      ProfileDispute[]
  mergeSources  ProfileMergeRequest[] @relation("MergeSource")
  mergeTargets  ProfileMergeRequest[] @relation("MergeTarget")
  disputesAsDuplicate ProfileDispute[]      @relation("DisputeDuplicateOf")

  @@index([ownerId])
  @@index([visibility])
  @@index([fullName])
  @@index([deletedAt])
}

// Расширенный доступ: editor / viewer на конкретный профиль (RBAC уровня сущности)
model ProfileAccess {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy String
  grantor   User     @relation("EditorGrants", fields: [grantedBy], references: [id], onDelete: Restrict)
  canEdit   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([profileId, userId])
  @@index([userId])
}

// ============================================================
//  CONTENT BLOCKS — типизированные блоки страницы (п. 1.4)
// ============================================================

model ContentBlock {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  type    String // жёстко типизирован enum
  title   String? // кастомный заголовок (для CUSTOM)
  body    String     // основной текст
  // Опциональное иллюстративное фото (одно — в зебра-вёрстке слева/справа)
  photoId String?
  photo   Media?    @relation("BlockPhoto", fields: [photoId], references: [id], onDelete: SetNull)

  order    Int // порядок сортировки
  isHidden Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Уникальность по (profileId, type) — для дефолтных блоков (1 CHILDHOOD на профиль).
  // CUSTOM-блоков может быть много; для них создаём отдельный частичный индекс в SQL миграции
  // (Prisma пока не поддерживает partial unique в schema.prisma).
  @@unique([profileId, order])
  @@index([profileId, type])
}

// ============================================================
//  GALLERY — фото-карусель страницы (отдельная сущность, не путать с блоками)
// ============================================================

model GalleryItem {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  mediaId   String
  media     Media    @relation("GalleryMedia", fields: [mediaId], references: [id], onDelete: Cascade)
  caption   String?
  order     Int
  createdAt DateTime @default(now())

  @@unique([profileId, order])
  @@index([profileId])
}

// ============================================================
//  GUEST MEMORIES — воспоминания посетителей (модерация)
// ============================================================

model GuestMemory {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  authorUserId String? // если оставил авторизованный
  authorUser   User?   @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  authorName   String // имя, отображаемое на карточке (может отличаться)

  type    String @default("TEXT")
  text    String?    
  mediaId String?
  media   Media?     @relation("MemoryMedia", fields: [mediaId], references: [id], onDelete: SetNull)

  isApproved   Boolean   @default(false) // модерация
  approvedAt   DateTime?
  approvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId, isApproved])
  @@index([authorUserId])
}

// ============================================================
//  CANDLE LIGHTS — свечи (счётчик заменён нормализованной таблицей)
// ============================================================

model CandleLight {
  id        String   @id @default(cuid())
  // Свеча может быть зажжена:
  //  - на главной (profileId = NULL) — общая «свеча памяти»
  //  - на конкретной странице памяти
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  // Анонимный fingerprint (IP+UA hash) для антифрод и rate-limit
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  fingerprint String?

  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
  @@index([userId])
  @@index([fingerprint, createdAt])
}

// ============================================================
//  FAMILY TREE
// ============================================================

model FamilyTree {
  id          String     @id @default(cuid())
  name        String // «Род Петровых»
  description String?    
  ownerId     String
  visibility  String @default("UNLISTED")
  accessHash  String?

  nodes FamilyNode[]
  clans FamilyClan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// ============================================================
//  FAMILY CLAN — род (для цветной подсветки линий в дереве)
// ============================================================

model FamilyClan {
  id          String       @id @default(cuid())
  treeId      String
  tree        FamilyTree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  name        String // «Род Ивановых»
  color       String       @default("#c8a84b") // hex для отрисовки нитей
  icon        String       @default("✦") // короткий символ (1-4 char)
  description String?      
  nodes       FamilyNode[]
  createdAt   DateTime     @default(now())

  @@unique([treeId, name])
  @@index([treeId])
}

// Узел дерева. Может (но не обязан) ссылаться на Profile (страницу памяти).
model FamilyNode {
  id     String     @id @default(cuid())
  treeId String
  tree   FamilyTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  // Имя и даты дублируются здесь, чтобы можно было строить дерево
  // без обязательной полноценной страницы памяти.
  firstName  String
  lastName   String?
  maidenName String?
  birthDate  DateTime?
  deathDate  DateTime?
  gender     String    @default("UNKNOWN")
  photoId    String?
  photo      Media?    @relation("NodePhoto", fields: [photoId], references: [id], onDelete: SetNull)

  clanId String?
  clan   FamilyClan? @relation(fields: [clanId], references: [id], onDelete: SetNull)
  notes  String?     

  // 1:1 со страницей памяти, если она есть (зеркало Profile.familyNodeId)
  profile Profile?

  // Реляционные связи (п. 1.2) — JSON parent_ids больше не нужен
  parentLinks FamilyConnection[] @relation("Child")
  childLinks  FamilyConnection[] @relation("Parent")

  // События жизни (п. 1.3) — напрямую связаны с узлом
  timelineEvents TimelineEvent[]

  // Позиция в схеме (для редактора дерева; опционально)
  posX       Float?
  posY       Float?
  generation Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treeId, generation])
  @@index([lastName, firstName])
}

// Самоссылающаяся таблица связей вместо JSON parent_ids.
// PARENT: fromNode = родитель, toNode = ребёнок (направленно).
// SPOUSE: записываем ОДНУ строку (fromNode < toNode по id) — приложение интерпретирует как двунаправленную.
model FamilyConnection {
  id         String     @id @default(cuid())
  fromNodeId String
  fromNode   FamilyNode @relation("Parent", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId   String
  toNode     FamilyNode @relation("Child", fields: [toNodeId], references: [id], onDelete: Cascade)

  type      String
  // Для SPOUSE: даты брака/развода
  startDate DateTime?
  endDate   DateTime?
  notes     String?

  createdAt DateTime @default(now())

  // Никаких дубликатов: одна связь определённого типа между двумя узлами
  @@unique([fromNodeId, toNodeId, type])
  @@index([toNodeId, type])
  @@index([fromNodeId, type])
}
// ============================================================
//  TIMELINE / ЛЕТОПИСЬ
// ============================================================

model TimelineEvent {
  id String @id @default(cuid())

  // Событие может относиться к:
  //   - конкретному родственнику (FamilyNode)   ← п. 1.3
  //   - конкретной странице (Profile)
  //   - быть «историческим» (оба NULL + category=HISTORICAL)
  familyNodeId String?
  familyNode   FamilyNode? @relation(fields: [familyNodeId], references: [id], onDelete: Cascade)
  profileId    String?
  profile      Profile?    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  category     String
  title        String
  description  String?          
  date         DateTime // точная дата
  dateAccuracy String? // "year" | "month" | "day"
  place        String?

  // 👇 НОВОЕ: ключ иконки для UI (star, book, war, flag, etc.)
  iconKey      String?

  // 👇 НОВОЕ: автор события (для HISTORICAL — кто из ADMIN добавил)
  createdById  String?
  createdBy    User?    @relation("TimelineEventAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  // 👇 НОВОЕ: soft delete (пригодится для отката исторических событий)
  deletedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyNodeId, date])
  @@index([profileId, date])
  @@index([category, date])
  @@index([createdById])
  @@index([deletedAt])
}

// ============================================================
//  MEDIA — единое хранилище для всех файлов (фото/аудио/видео)
// ============================================================

model Media {
  id           String    @id @default(cuid())
  kind         String
  url          String // путь относительно /uploads/
  originalName String?
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  durationSec  Int? // для audio/video

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  // Обратные связи (для каскадного удаления и анализа)
  profileCover      Profile?       @relation("ProfileCover")
  galleryItems      GalleryItem[]  @relation("GalleryMedia")
  blockPhotos       ContentBlock[] @relation("BlockPhoto")
  nodePhotos        FamilyNode[]   @relation("NodePhoto")
  memoryAttachments GuestMemory[]  @relation("MemoryMedia")

  @@index([uploadedById])
  @@index([kind])
}

// ============================================================
//  QR ТАБЛИЧКИ
// ============================================================

model QrPlaque {
  id        String    @id @default(cuid())
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  code      String    @unique // короткий код для /qr/:code
  isActive  Boolean   @default(true)
  orderedAt DateTime  @default(now())
  shippedAt DateTime?

  @@index([profileId])
}

// ============================================================
//  PROFILE ACCESS CODE — пин-код для PASSWORD-страниц
//  (на случай нескольких ротируемых кодов; основной хеш живёт в Profile.accessHash)
// ============================================================

model ProfileAccessCode {
  id        String    @id @default(cuid())
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  // Не храним plaintext: PBKDF2 в формате "iterations:saltHex:hashHex"
  codeHash  String
  label     String? // «Для семьи», «Для коллег»
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([profileId])
}



model AuditLog {
  id          String      @id @default(cuid())
  action      String
  userId      String?     // кто (null для LOGIN_FAILED по неизвестному email)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  entityType  String?     // 'Profile' | 'FamilyTree' | 'User' | 'AccessCode' | null
  entityId    String?     // ID того, на что подействовали
  oldValue    Json?       // прежнее состояние полей
  newValue    Json?       // новое состояние полей
  metadata    Json?       // { email, ip, userAgent, ... } — свободная форма
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([createdAt])
}


model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================
// === Disputes / Merge / Legacy Contact (Phase 1) ============
// ============================================================











// --- Disputes -----------------------------------------------

model ProfileDispute {
  id          String        @id @default(cuid())

  profileId   String
  profile     Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)

  reporterId  String
  reporter    User          @relation("DisputeReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  reason      String
  description String        
  evidence    String?         // ссылки на документы, имена файлов

  status      String @default("OPEN")
  resolverId  String?                  // ADMIN userId (без FK — оставим String для гибкости)
  resolution  String?       
  resolvedAt  DateTime?

  // Если reason = DUPLICATE — какой профиль является оригиналом
  duplicateOfProfileId String?
  duplicateOfProfile   Profile? @relation("DisputeDuplicateOf", fields: [duplicateOfProfileId], references: [id], onDelete: SetNull)

  // Если reason = DUPLICATE — линкуется к merge request 1:1
  mergeRequestId String?              @unique
  mergeRequest   ProfileMergeRequest? @relation(fields: [mergeRequestId], references: [id], onDelete: SetNull)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([profileId])
  @@index([reporterId])
  @@index([status])
  @@index([reason])
  @@index([duplicateOfProfileId])
  @@index([createdAt])
}

// --- Merge Request -------------------------------------------

model ProfileMergeRequest {
  id              String      @id @default(cuid())

  // source merges INTO target; source становится soft-deleted
  sourceProfileId String
  sourceProfile   Profile     @relation("MergeSource", fields: [sourceProfileId], references: [id], onDelete: Cascade)

  targetProfileId String
  targetProfile   Profile     @relation("MergeTarget", fields: [targetProfileId], references: [id], onDelete: Cascade)

  requesterId     String
  requester       User        @relation("MergeRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  reason          String?     

  status          String @default("PENDING_OWNERS")

  // Two-step approval: оба owner → ADMIN
  sourceOwnerApprovedAt DateTime?
  sourceOwnerApprovedBy String?
  targetOwnerApprovedAt DateTime?
  targetOwnerApprovedBy String?
  adminApprovedAt       DateTime?
  adminApprovedBy       String?

  executedAt      DateTime?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?     

  // Обратная сторона 1:1 с ProfileDispute.mergeRequest
  dispute         ProfileDispute?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([sourceProfileId])
  @@index([targetProfileId])
  @@index([requesterId])
  @@index([status])
  @@index([createdAt])
}

// --- Legacy Contact -----------------------------------------

model LegacyContact {
  id              String              @id @default(cuid())

  // 1:1 — у каждого user'а ровно один наследник
  ownerId         String              @unique
  owner           User                @relation("LegacyContactOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Наследник: либо существующий User (после accept invite), либо просто email
  heirUserId      String?
  heirUser        User?               @relation("LegacyContactHeir", fields: [heirUserId], references: [id], onDelete: SetNull)
  heirEmail       String
  heirName        String?

  status          String @default("PENDING")

  // Invite flow (token = SHA-256 hex)
  inviteTokenHash String?             @unique
  inviteExpiresAt DateTime?
  inviteSentAt    DateTime?
  verifiedAt      DateTime?

  // Trigger flow
  triggeredAt     DateTime?

  // Per-contact override (default 90, синхронизируется с User.legacyInactivityDays при create)
  inactivityDays  Int                 @default(90)
  message         String?               // прощальное сообщение наследнику

  revokedAt       DateTime?

  claims          LegacyClaim[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([heirUserId])
  @@index([heirEmail])
  @@index([status])
  @@index([triggeredAt])
}

// --- Legacy Claim -------------------------------------------

model LegacyClaim {
  id              String            @id @default(cuid())

  legacyContactId String
  legacyContact   LegacyContact     @relation(fields: [legacyContactId], references: [id], onDelete: Cascade)

  claimantId      String
  claimant        User              @relation(fields: [claimantId], references: [id], onDelete: Cascade)

  status          String @default("PENDING")
  evidence        String?           

  // ADMIN review (resolverId без FK — String)
  reviewerId      String?
  reviewedAt      DateTime?
  reviewNotes     String?           

  expiresAt       DateTime          // обычно +30 дней с createdAt

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([legacyContactId])
  @@index([claimantId])
  @@index([status])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────
// Telegram deep-link login (Phase 3) — без widget/домена
// ─────────────────────────────────────────────────────────────


model TgLoginToken {
  id           String        @id @default(cuid())
  token        String        @unique
  status       String @default("PENDING")
  userId       String?
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  expiresAt    DateTime
  confirmedAt  DateTime?
  consumedAt   DateTime?
  createdAt    DateTime      @default(now())

  @@index([status, expiresAt])
}
