# ─────────────────────────────────────────────────────────────
#  Общая конфигурация сайта. Используется и на боевом домене (HTTPS),
#  и на :80 (прямой доступ по IP / локальная отладка).
# ─────────────────────────────────────────────────────────────
(app) {
	root * /srv
	encode gzip zstd

	# === API → backend ===
	handle /api/* {
		# Приватность: API не должно попадать в индекс/ИИ-обучение
		header X-Robots-Tag "noindex, nofollow"
		reverse_proxy backend:3000
	}

	# === SEO на корне → backend ===
	handle /sitemap.xml {
		reverse_proxy backend:3000
	}
	handle /robots.txt {
		reverse_proxy backend:3000
	}
	handle /health {
		reverse_proxy backend:3000
	}

	# === Загруженные файлы профилей (proxy → backend express.static) ===
	handle /uploads/* {
		# Приватность: фото (в т.ч. непубличных профилей) не индексируем
		header X-Robots-Tag "noindex"
		reverse_proxy backend:3000
	}

	# === OG-рендер страниц памяти → backend ===
	handle /p/* {
		reverse_proxy backend:3000
	}

	# === Статика фронта + fallback на .html ===
	handle {
		# __CACHE_CONTROL_V1__
		# Статика (js/css/шрифты/картинки) версионируется через ?v= в HTML,
		# поэтому кешируем надолго: меньше revalidate-запросов → быстрее LCP и
		# повторные загрузки. При обновлении ассета поднимай ?v= (для css/js)
		# или переименуй файл (для картинок/шрифтов).
		@static path *.js *.css *.png *.jpg *.jpeg *.svg *.gif *.ico *.webp *.woff *.woff2 *.ttf *.map
		header @static Cache-Control "public, max-age=31536000, immutable"

		# HTML всегда свежий (там лежат ?v= и SEO-мета), без долгого кеша.
		@html {
			not path *.js *.css *.png *.jpg *.jpeg *.svg *.gif *.ico *.webp *.woff *.woff2 *.ttf *.map
		}
		header @html Cache-Control "no-cache, must-revalidate"

		try_files {path} {path}.html /index.html
		file_server
	}

	log {
		output stdout
		format console
	}
}

# ─────────────────────────────────────────────────────────────
#  Боевой домен. Caddy сам получит и продлит TLS-сертификат
#  (Let's Encrypt). HTTP автоматически редиректит на HTTPS.
#  Требование: DNS A/AAAA qr-memory.by → IP сервера, порты 80 и 443 открыты.
# ─────────────────────────────────────────────────────────────
qr-memory.by {
	import app
	# HSTS: TLS терминируется на Caddy, поэтому заголовок ставим здесь
	# (а не в helmet на бэкенде, который ходит по http внутри сети).
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
}

# www → без www: единый канонический хост (301).
www.qr-memory.by {
	redir https://qr-memory.by{uri} permanent
}

# Фолбэк: прямой доступ по IP / локальная отладка без TLS.
:80 {
	import app
}
