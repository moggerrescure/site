# === Postgres ===
POSTGRES_DB=memorial_site
POSTGRES_USER=memorial
POSTGRES_PASSWORD=change_me_to_random_32_chars

# === Backend ===
JWT_SECRET=generate_with_openssl_rand_base64_64
SITE_URL=http://localhost

# === Bot ===
BOT_TOKEN=your_telegram_bot_token_hereBOT_USERNAME=YourBot_bot   # username TG-бота без @ (для deep-link login)

# === S3 / R2 storage (optional — без этого fallback на local /uploads) ===
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_PUBLIC_URL_BASE=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Telegram chat id для пересылки сообщений поддержки боту и админ-алертов
ADMIN_CHAT_ID=

# === AI (OpenAI-совместимый провайдер, напр. aihubmix) ===
AI_BASE_URL=https://aihubmix.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
# таймаут запроса к ИИ, мс (необязательно)
AI_TIMEOUT_MS=30000